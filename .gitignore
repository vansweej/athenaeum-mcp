# Rust build artefacts
/target/

# Nix build outputs
result
result-*

# LanceDB data store — never committed
.lancedb/
*.lance
data/

# Corpus — copyrighted books must never leave the local machine (see docs/decision-brief.md)
corpus/
*.epub
*.pdf
*.mobi

# Exception: self-authored canary fixtures are safe to commit
!crates/parser-spike/tests/fixtures/*.epub
!crates/parser-spike/tests/fixtures/*.pdf

# Environment secrets
.env
.env.*

# macOS
.DS_Store
